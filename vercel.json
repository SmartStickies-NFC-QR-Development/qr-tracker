{
  "version": 2,
  "builds": [
    { "src": "app/main.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/app/static/$1" },
    { "src": "/(member-portal|admin-dashboard|inventory)\\.html", "dest": "/$1.html" },
    { "src": "/(.*)", "dest": "app/main.py" }
  ]
}
